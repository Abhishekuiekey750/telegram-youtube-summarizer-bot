# Telegram Bot (example values, replace with your own)
TELEGRAM_BOT_TOKEN=your_telegram_token_here
TELEGRAM_MODE=polling
# TELEGRAM_ALLOWED_USERS=user1,user2  # Optional: restrict access

# YouTube Data API (for video metadata)
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- OpenClaw (see INSTALL_OPENCLAW.md for install steps) ---
# Add these two lines to your .env after installing and starting OpenClaw gateway.
# Use the same token as in OpenClaw config gateway.auth.token.
# OPENAI_BASE_URL=http://127.0.0.1:18789/v1
# OPENAI_API_KEY=your_gateway_token

# --- Or use OpenRouter (many models, OpenAI-compatible API) ---
# Get key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...   (or OPEN_ROUTER_KEY=sk-or-...)
# OPENROUTER_MODEL=openai/gpt-3.5-turbo

# --- Or use OpenAI directly (no OpenClaw) ---
# OPENAI_API_KEY=sk-your-openai-key

# --- Or use Google Gemini (free tier) ---
# Get key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash

# Optional
# ENVIRONMENT=development
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080
